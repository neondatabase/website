{
  "name": "neon-nextjs",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=8.6.0"
  },
  "scripts": {
    "prebuild": "node src/scripts/update-github-stars.js && node src/scripts/generate-docs-icons-config.js && npm run check:content-data && npm run generate:pricing",
    "predev": "node src/scripts/update-github-stars.js && node src/scripts/generate-docs-icons-config.js && npm run check:content-data && npm run generate:pricing",
    "dev": "next dev",
    "build": "next build",
    "dev:build": "next build",
    "postbuild": "node src/scripts/copy-md-content.js && node src/scripts/generate-llms-index.js && node src/scripts/generate-llms-full.js && next-sitemap --config next-sitemap.config.js && next-sitemap --config next-sitemap-postgres.config.js",
    "start": "next start",
    "format": "prettier --write --log-level warn --cache .",
    "fix": "eslint --fix --quiet --cache . && markdownlint --fix --ignore-path .gitignore .; prettier --write --log-level warn --cache .",
    "lint": "npm run lint:js && npm run lint:md",
    "lint:js": "eslint .",
    "lint:md": "markdownlint --ignore-path .gitignore .",
    "check:broken-links": "linkinator --config linkinator.config.json",
    "check:pricing-sync": "node src/scripts/check-pricing-sync.js",
    "check:content-data": "node scripts/validate-content-data.js",
    "generate:pricing": "node src/scripts/check-pricing-sync.js --generate",
    "prepare": "husky install",
    "test": "npx cypress open",
    "test:unit": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:run": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "check:docs": "vitest run scripts/docs-checks/**/__tests__/*.test.js",
    "check:docs:neonctl": "vitest run scripts/docs-checks/neonctl/__tests__/neonctl-docs.test.js"
  },
  "dependencies": {
    "@emotion/memoize": "0.7.4",
    "@codemirror/lang-sql": "^6.9.1",
    "@headlessui/react": "^2.2.9",
    "@headlessui/tailwindcss": "^0.2.2",
    "@hookform/resolvers": "^3.3.4",
    "@inkeep/cxkit-react": "^0.5.116",
    "@neondatabase/api-client": "^1.12.0",
    "@neondatabase/serverless": "^0.10.4",
    "@next/bundle-analyzer": "^16.1.6",
    "@octokit/core": "^6.1.2",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@react-hook/throttle": "^2.2.0",
    "@react-hook/window-scroll": "^1.3.0",
    "@rive-app/react-canvas": "^4.20.0",
    "@segment/analytics-next": "^1.67.0",
    "@splinetool/react-spline": "^2.2.6",
    "@supabase/sql-to-rest": "^0.1.8",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@uiw/codemirror-theme-github": "^4.25.1",
    "@uiw/react-codemirror": "^4.25.1",
    "@upstash/qstash": "^2.8.1",
    "@upstash/ratelimit": "^2.0.5",
    "@vercel/analytics": "^1.6.1",
    "async-retry": "^1.3.3",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "clsx": "^2.1.1",
    "copy-to-clipboard": "^3.3.3",
    "dotenv": "^16.4.5",
    "file-loader": "^6.2.0",
    "framer-motion": "^12.36.0",
    "geist": "^1.5.1",
    "glob": "^10.5.0",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0",
    "gray-matter": "^4.0.3",
    "gsap": "^3.12.5",
    "he": "^1.2.0",
    "hls.js": "^1.5.8",
    "html-react-parser": "^5.2.17",
    "js-yaml": "^4.1.0",
    "lodash.get": "^4.4.2",
    "lodash.isboolean": "^3.0.3",
    "lodash.isempty": "^4.4.0",
    "lodash.shuffle": "^4.2.0",
    "lottie-web": "^5.12.2",
    "markdownlint-cli": "^0.48.0",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-mdx": "^3.0.0",
    "mdast-util-to-markdown": "^2.1.2",
    "mermaid": "^11.13.0",
    "next": "^16.1.6",
    "next-mdx-remote": "^6.0.0",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.298.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.51.3",
    "react-icons": "^5.6.0",
    "react-intersection-observer": "^9.8.2",
    "react-medium-image-zoom": "^5.4.1",
    "react-paginate": "^8.3.0",
    "react-scroll": "^1.9.3",
    "react-share": "^5.3.0",
    "react-tooltip": "^5.26.3",
    "react-use": "^17.5.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "rss": "^1.2.2",
    "slugify": "^1.6.6",
    "swiper": "^12.1.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-safe-area": "^0.5.1",
    "unified": "^11.0.5",
    "unique-username-generator": "^1.4.0",
    "unist-util-visit": "^5.0.0",
    "vaul": "^1.1.2",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@eslint/compat": "^1.2.0",
    "@eslint/js": "^9.0.0",
    "@next/eslint-plugin-next": "^16.2.1",
    "@shikijs/transformers": "^1.3.0",
    "@svgr/webpack": "^8.1.0",
    "@vitest/ui": "^4.0.2",
    "cypress": "^13.8.0",
    "encoding": "^0.1.13",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-cypress": "^4.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^16.0.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "postcss": "^8.4.38",
    "postcss-nesting": "^14.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shiki": "^1.1.1",
    "svgo-loader": "^4.0.0",
    "tailwindcss": "^4.2.1",
    "url-loader": "^4.1.1",
    "vitest": "^4.0.2"
  }
}
